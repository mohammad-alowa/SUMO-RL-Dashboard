<?xml version="1.0" encoding="UTF-8"?>
<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://sumo.dlr.de/xsd/routes_file.xsd">
    
    <!-- Vehicle Types -->
    <vType id="car" accel="2.6" decel="4.5" sigma="0.5" length="5" maxSpeed="50" vClass="passenger" color="0.9,0.9,0.9"/>
    <vType id="emergency" accel="4.0" decel="6.0" sigma="0" length="6.5" maxSpeed="75" vClass="emergency" color="1,0,0"/>
    
    <!-- Routes -->
    <route id="route_ew" edges="Node1_2_EB -E2Node2_3_EB"/>
    <route id="route_we" edges="-E2Node2_3_WB Node1_2_WB"/>
    <route id="route_ns" edges="Node2_7_SB -E2Node2_5_SB"/>
    <route id="route_sn" edges="-E2Node2_5_NB Node2_7_NB"/>
    
    <!-- MOSTLY NORMAL CARS - High Flow -->
    <flow id="cars_ew" type="car" route="route_ew" begin="0" end="3600" vehsPerHour="500"/>
    <flow id="cars_we" type="car" route="route_we" begin="0" end="3600" vehsPerHour="500"/>
    <flow id="cars_ns" type="car" route="route_ns" begin="0" end="3600" vehsPerHour="400"/>
    <flow id="cars_sn" type="car" route="route_sn" begin="0" end="3600" vehsPerHour="400"/>
    
    <!-- Emergency Vehicles - 12 total spread over 30 minutes -->
    <vehicle id="emerg_1" type="emergency" route="route_ew" depart="90" color="1,0,0"/>
    <vehicle id="emerg_2" type="emergency" route="route_ns" depart="180" color="1,0,0"/>
    <vehicle id="emerg_3" type="emergency" route="route_we" depart="270" color="1,0,0"/>
    <vehicle id="emerg_4" type="emergency" route="route_sn" depart="360" color="1,0,0"/>
    <vehicle id="emerg_5" type="emergency" route="route_ew" depart="450" color="1,0,0"/>
    <vehicle id="emerg_6" type="emergency" route="route_ns" depart="540" color="1,0,0"/>
    <vehicle id="emerg_7" type="emergency" route="route_we" depart="630" color="1,0,0"/>
    <vehicle id="emerg_8" type="emergency" route="route_sn" depart="720" color="1,0,0"/>
    <vehicle id="emerg_9" type="emergency" route="route_ew" depart="810" color="1,0,0"/>
    <vehicle id="emerg_10" type="emergency" route="route_ns" depart="900" color="1,0,0"/>
    <vehicle id="emerg_11" type="emergency" route="route_we" depart="1080" color="1,0,0"/>
    <vehicle id="emerg_12" type="emergency" route="route_ew" depart="1260" color="1,0,0"/>
    <vehicle id="emerg_13" type="emergency" route="route_sn" depart="1440" color="1,0,0"/>
    <vehicle id="emerg_14" type="emergency" route="route_ns" depart="1620" color="1,0,0"/>
    <vehicle id="emerg_15" type="emergency" route="route_we" depart="1800" color="1,0,0"/>
    
</routes>